---
/**
 * Button polimórfico — puede renderizar como <a> o <button>.
 * Variantes: primary, ghost, outline, whatsapp.
 */
type Variant = 'primary' | 'ghost' | 'outline' | 'whatsapp';

interface PropsAsLink extends astroHTML.JSX.AnchorHTMLAttributes {
  href: string;
  variant?: Variant;
}
interface PropsAsButton extends astroHTML.JSX.ButtonHTMLAttributes {
  href?: undefined;
  variant?: Variant;
}
type Props = PropsAsLink | PropsAsButton;

const { variant = 'primary', class: className, ...rest } = Astro.props;
const classes = ['btn', `btn--${variant}`, className].filter(Boolean).join(' ');
const Tag = 'href' in rest && rest.href ? 'a' : 'button';
---

<Tag class={classes} {...rest as any}>
  <slot />
</Tag>
