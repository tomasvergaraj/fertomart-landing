---
/**
 * Iconos SVG inline reutilizables.
 * Inline (no <img>) para que tomen el color del padre con currentColor.
 */
interface Props {
  name:
    | 'instagram'
    | 'facebook'
    | 'whatsapp'
    | 'arrow-right'
    | 'phone'
    | 'clock'
    | 'map-pin'
    | 'star'
    | 'check'
    | 'close'
    | 'chevron-left'
    | 'chevron-right'
    | 'external';
  size?: number;
  class?: string;
}

const { name, size = 18, class: className } = Astro.props;
---

{
  name === 'instagram' && (
    <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class={className}>
      <rect x="3" y="3" width="18" height="18" rx="5" />
      <circle cx="12" cy="12" r="4" />
      <circle cx="17.5" cy="6.5" r="0.9" fill="currentColor" stroke="none" />
    </svg>
  )
}
{
  name === 'facebook' && (
    <svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class={className}>
      <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.99 3.66 9.13 8.44 9.88v-6.99H7.9V12h2.54V9.8c0-2.51 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99C18.34 21.13 22 16.99 22 12z" />
    </svg>
  )
}
{
  name === 'whatsapp' && (
    <svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class={className}>
      <path d="M17.6 6.32A7.85 7.85 0 0012.05 4a7.94 7.94 0 00-6.88 11.9L4 20l4.2-1.1a7.93 7.93 0 003.85 1h.01a7.94 7.94 0 005.54-13.58zM12.05 18.55a6.6 6.6 0 01-3.36-.92l-.24-.14-2.5.65.67-2.44-.16-.25a6.6 6.6 0 1112.22-3.51 6.55 6.55 0 01-6.63 6.61zm3.62-4.94c-.2-.1-1.18-.58-1.36-.65-.18-.07-.31-.1-.45.1-.13.2-.5.65-.62.78-.11.13-.23.15-.43.05a5.4 5.4 0 01-1.6-.99 6 6 0 01-1.1-1.37c-.12-.2 0-.3.09-.4.09-.09.2-.23.3-.34.1-.12.13-.2.2-.33.06-.13.03-.25-.02-.35-.05-.1-.45-1.08-.62-1.48-.16-.39-.33-.34-.45-.34h-.39a.75.75 0 00-.54.25 2.27 2.27 0 00-.7 1.68 3.94 3.94 0 00.82 2.1 9 9 0 003.45 3.04c.48.2.86.33 1.15.42.49.16.93.13 1.28.08.39-.06 1.18-.48 1.35-.95.17-.46.17-.86.12-.95-.05-.08-.18-.13-.38-.23z" />
    </svg>
  )
}
{
  name === 'arrow-right' && (
    <svg width={size} height={size} viewBox="0 0 16 16" fill="none" aria-hidden="true" class={className}>
      <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
{
  name === 'phone' && (
    <svg width={size} height={size} viewBox="0 0 16 16" fill="none" aria-hidden="true" class={className}>
      <path d="M3 3h3l1.5 4-2 1a8 8 0 004 4l1-2 4 1.5V14a1 1 0 01-1 1A12 12 0 012 4a1 1 0 011-1z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" />
    </svg>
  )
}
{
  name === 'clock' && (
    <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class={className}>
      <circle cx="12" cy="12" r="9" />
      <path d="M12 7v5l3 2" />
    </svg>
  )
}
{
  name === 'map-pin' && (
    <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class={className}>
      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
      <circle cx="12" cy="10" r="3" />
    </svg>
  )
}
{
  name === 'star' && (
    <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class={className}>
      <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z" />
