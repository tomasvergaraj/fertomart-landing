  )
}
{
  name === 'check' && (
    <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class={className}>
      <path d="M20 6L9 17l-5-5" />
    </svg>
  )
}
{
  name === 'close' && (
    <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" class={className}>
      <path d="M6 6l12 12M18 6L6 18" />
    </svg>
  )
}
{
  name === 'chevron-left' && (
    <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class={className}>
      <path d="M15 6l-6 6 6 6" />
    </svg>
  )
}
{
  name === 'chevron-right' && (
    <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class={className}>
      <path d="M9 6l6 6-6 6" />
    </svg>
  )
}
{
  name === 'external' && (
    <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class={className}>
      <path d="M7 17L17 7M9 7h8v8" />
    </svg>
  )
}
