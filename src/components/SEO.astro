---
/**
 * Componente <SEO /> reutilizable.
 * Genera meta tags estándar, Open Graph, Twitter Card y JSON-LD.
 * Recibe props para personalizar por página; cae en defaults razonables.
 */
import { SITE } from '~/data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  schemas?: Record<string, unknown>[];
}

const {
  title = `${SITE.name} · Eventos y Banquetería en Chile | 25 años`,
  description = SITE.description,
  image = `${SITE.url}/og-image.jpg`,
  canonical = Astro.url.href,
  schemas = [],
} = Astro.props;
---

<!-- SEO primario -->
<title>{title}</title>
<meta name="description" content={description} />
<meta
  name="keywords"
  content="eventos gastronómicos, banquetería Chile, servicio de banquetería, parrilla para eventos, asado para eventos, catering carnes, organización de fiestas, eventos corporativos, matrimonios, cumpleaños, Fertomart"
/>
<meta name="author" content={SITE.legalName} />
<meta name="robots" content="index, follow, max-image-preview:large" />
<meta name="googlebot" content="index, follow" />
<link rel="canonical" href={canonical} />

<!-- Geo tags para SEO local -->
<meta name="geo.region" content="CL" />
<meta name="geo.placename" content="Chile" />
<meta name="ICBM" content="-33.4489, -70.6693" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:locale" content="es_CL" />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={image} />
<meta property="og:image:secure_url" content={image} />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${SITE.name} Eventos Gastronómicos — Especialistas en carnes`} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />

<!-- JSON-LD: se inyectan los schemas que reciba el componente -->
{
  schemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
