---
/**
 * Componente <SEO /> reutilizable.
 * Genera meta tags estándar, Open Graph, Twitter Card y JSON-LD.
 * Recibe props para personalizar por página; cae en defaults razonables.
 */
import { SITE } from '~/data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  schemas?: Record<string, unknown>[];
}

const {
  title = `${SITE.name} · Banquetería y Eventos en Hijuelas, V Región | 25 años`,
  description = SITE.description,
  image = `${SITE.url}/og-image.jpg`,
  canonical = Astro.url.href,
  schemas = [],
} = Astro.props;
---

<!-- SEO primario -->
<title>{title}</title>
<meta name="description" content={description} />
<meta
  name="keywords"
  content="banquetería Hijuelas, banquetería Quillota, banquetería V Región, catering Valparaíso, cordero al palo, asado al palo a domicilio, parrilla para eventos, servicio de banquetería matrimonios, eventos corporativos Valparaíso, catering cumpleaños, Fertomart"
/>
<meta name="author" content={SITE.legalName} />
<meta name="robots" content="index, follow, max-image-preview:large" />
<meta name="googlebot" content="index, follow" />
<link rel="canonical" href={canonical} />

<!-- Geo tags para SEO local (Hijuelas, V Región) -->
<meta name="geo.region" content="CL-VS" />
<meta name="geo.placename" content="Hijuelas, Región de Valparaíso, Chile" />
<meta name="geo.position" content="-32.835766;-71.112385" />
<meta name="ICBM" content="-32.835766, -71.112385" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:locale" content="es_CL" />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={image} />
<meta property="og:image:secure_url" content={image} />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${SITE.name} Eventos Gastronómicos — Especialistas en carnes`} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />

<!-- JSON-LD: se inyectan los schemas que reciba el componente -->
{
  schemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
