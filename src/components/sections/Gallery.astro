---
/**
 * Galería con grid asimétrico (los `featured` ocupan 2 columnas en desktop).
 * Las imágenes vienen de la collection y se resuelven dinámicamente
 * con import.meta.glob para que Astro las optimice.
 */
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import SectionHead from '~/components/ui/SectionHead.astro';
import Icon from '~/components/ui/Icon.astro';
import { SOCIAL } from '~/data/site';

const gallery = (await getCollection('gallery')).sort(
  (a, b) => a.data.order - b.data.order
);

// Astro necesita conocer las rutas de los assets en tiempo de build.
// import.meta.glob con eager+import:default los importa todos como ImageMetadata.
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/events/*.{jpg,jpeg,png,webp,svg}',
  { eager: true, import: 'default' }
);

function getImage(filename: string): ImageMetadata {
  const path = `/src/assets/events/${filename}`;
  const img = images[path];
  if (!img) {
    throw new Error(
      `Imagen no encontrada: ${path}. Revisa que el archivo existe en src/assets/events/.`
    );
  }
  return img as unknown as ImageMetadata;
}
---

<section class="gallery" id="galeria" aria-labelledby="gallery-title">
  <div class="container">
    <SectionHead
      eyebrow="Galería"
      align="center"
      id="gallery-title"
      subtitle="Cada celebración es única. Estos son momentos de fiestas, matrimonios y eventos corporativos donde Fertomart estuvo a cargo del servicio."
    >
      Algunos <em>eventos</em> que hemos realizado
    </SectionHead>

    <div class="gallery__grid" role="list">
      {gallery.map((item) => (
        <button
          type="button"
          class:list={['gallery__item reveal', { 'gallery__item--lg': item.data.featured }]}
          data-lightbox-trigger
          aria-label={`Ver: ${item.data.caption}`}
          role="listitem"
        >
          <Image
            src={getImage(item.data.image)}
            alt={item.data.alt}
            width={800}
            height={600}
            loading="lazy"
          />
          <span class="gallery__caption">{item.data.caption}</span>
        </button>
      ))}
    </div>

    <p class="gallery__swipe-hint" aria-hidden="true">Desliza para ver más →</p>

    <p class="gallery__note">
      ¿Quieres ver más?
      <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer">
        Síguenos en Instagram
        <Icon name="external" size={14} />
      </a>
    </p>
  </div>
</section>

<style>
  .gallery {
    padding: var(--space-section) 0;
    background: var(--color-bg-deep);
  }
  /* En móvil: carrusel horizontal con scroll-snap. Cada item ocupa ~85% del ancho. */
  .gallery__grid {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 85%;
    gap: 1rem;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-padding-inline: 1rem;
    padding: 0.5rem 1rem 1.25rem;
    margin: 0 calc(var(--container-padding, 1.25rem) * -1);
    scrollbar-width: thin;
    scrollbar-color: var(--color-wine) transparent;
    -webkit-overflow-scrolling: touch;
  }
  .gallery__grid::-webkit-scrollbar {
    height: 6px;
  }
  .gallery__grid::-webkit-scrollbar-thumb {
    background: var(--color-wine);
    border-radius: 3px;
  }
  .gallery__swipe-hint {
    margin-top: 0.25rem;
    text-align: center;
    font-size: 0.8125rem;
    color: var(--color-ink-soft);
    letter-spacing: 0.05em;
  }
  .gallery__item {
    position: relative;
    overflow: hidden;
    border-radius: 6px;
    background: var(--color-ink);
    aspect-ratio: 4 / 3;
    cursor: zoom-in;
    isolation: isolate;
    appearance: none;
    border: none;
    padding: 0;
    text-align: left;
    color: inherit;
    font-family: inherit;
    font-size: inherit;
    scroll-snap-align: center;
    /* Animación de zoom-in/out al entrar y salir del viewport del carrusel */
    transform: scale(0.92);
    opacity: 0.7;
    transition: transform 0.4s var(--ease), opacity 0.4s var(--ease);
  }
  /* Navegadores con scroll-driven animations: animación nativa, suave y por GPU */
  @supports (animation-timeline: view()) {
    .gallery__item {
      transform: none;
      opacity: 1;
      animation: gallerySnap linear both;
      animation-timeline: view(inline);
      animation-range: cover 5% cover 95%;
    }
    @keyframes gallerySnap {
      0%   { transform: scale(0.88); opacity: 0.55; }
      50%  { transform: scale(1);    opacity: 1; }
      100% { transform: scale(0.88); opacity: 0.55; }
    }
  }
  /* Fallback: el item activo se marca por IntersectionObserver */
  .gallery__item.is-active {
    transform: scale(1);
    opacity: 1;
  }
  .gallery__item :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease), filter 0.5s var(--ease);
  }
  .gallery__item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(15, 14, 12, 0.7) 0%, rgba(15, 14, 12, 0.1) 50%, transparent 100%);
    opacity: 0;
    transition: opacity 0.4s var(--ease);
  }
  .gallery__item:hover :global(img) {
    transform: scale(1.06);
    filter: brightness(1.05);
  }
  .gallery__item:hover::after,
  .gallery__item:focus-visible::after {
    opacity: 1;
  }
  .gallery__caption {
    position: absolute;
    left: 1.25rem;
    bottom: 1.25rem;
    z-index: 1;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--color-bg);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s var(--ease), transform 0.4s var(--ease);
  }
  .gallery__item:hover .gallery__caption,
  .gallery__item:focus-visible .gallery__caption {
    opacity: 1;
    transform: translateY(0);
  }
  @media (hover: none) {
    .gallery__item::after {
      opacity: 1;
    }
    .gallery__caption {
      opacity: 1;
      transform: none;
    }
  }

  .gallery__note {
    margin-top: 2.5rem;
    text-align: center;
    font-size: 0.9375rem;
    color: var(--color-ink-soft);
  }
  .gallery__note a {
    color: var(--color-wine);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-left: 0.35rem;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: color 0.3s var(--ease);
  }
  .gallery__note a:hover {
    color: var(--color-ember);
  }

  @media (min-width: 640px) {
    .gallery__grid {
      grid-auto-flow: row;
      grid-auto-columns: auto;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
      overflow: visible;
      scroll-snap-type: none;
      padding: 0;
      margin: 0;
    }
    .gallery__item {
      transform: none;
      opacity: 1;
      animation: none;
      scroll-snap-align: none;
    }
    .gallery__swipe-hint {
      display: none;
    }
  }
  @media (min-width: 960px) {
    .gallery__grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-flow: dense;
      gap: 1.5rem;
    }
    .gallery__item--lg {
      grid-column: span 2;
      aspect-ratio: 16 / 9;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .gallery__item {
      transform: none;
      opacity: 1;
      animation: none;
      transition: none;
    }
  }
</style>

<script>
  /**
   * Fallback para el carrusel móvil de la galería:
   * en navegadores sin `animation-timeline: view()`, marca el item más cercano
   * al centro del scroller con `.is-active` para mantener la animación visual
   * de escala/opacidad al deslizar.
   */
  const grid = document.querySelector<HTMLElement>('.gallery__grid');
  const supportsScrollAnim =
    typeof CSS !== 'undefined' && CSS.supports?.('animation-timeline: view()');

  if (grid && !supportsScrollAnim && 'IntersectionObserver' in window) {
    const items = Array.from(grid.querySelectorAll<HTMLElement>('.gallery__item'));
    const obs = new IntersectionObserver(
      (entries) => {
        // Sólo aplicamos en el modo carrusel (ancho < 640px aprox)
        if (window.innerWidth >= 640) {
          items.forEach((el) => el.classList.remove('is-active'));
          return;
        }
        entries.forEach((entry) => {
          if (entry.intersectionRatio >= 0.7) {
            entry.target.classList.add('is-active');
          } else {
            entry.target.classList.remove('is-active');
          }
        });
      },
      {
        root: grid,
        threshold: [0, 0.3, 0.7, 1],
      }
    );
    items.forEach((el) => obs.observe(el));
  }
</script>
