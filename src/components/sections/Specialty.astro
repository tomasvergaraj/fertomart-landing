---
/**
 * Especialidad: carnes — sección oscura con video del evento real al costado.
 * El video carga sólo cuando entra en viewport (lazy + IntersectionObserver).
 */
import SectionHead from '~/components/ui/SectionHead.astro';
import specialtyVideoMp4 from '~/assets/specialty-video.mp4';
import specialtyPoster from '~/assets/specialty-poster.jpg';
---

<section class="specialty" id="especialidad" aria-labelledby="specialty-title">
  <div class="container specialty__inner">
    <div class="specialty__text reveal">
      <SectionHead
        eyebrow="Nuestra especialidad"
        id="specialty-title"
        titleVariant="light"
      >
        Todo tipo de <em>carnes</em>,<br />
        cocinadas con criterio.
      </SectionHead>
      <p class="specialty__lead">
        Veinticinco años aprendiendo el oficio. Conocemos los tiempos, los cortes
        y el punto exacto. Esa experiencia es lo que separa un buen evento
        de uno inolvidable.
      </p>

      <ul class="specialty__list" role="list">
        <li>Parrilla en vivo y asados al estilo chileno</li>
        <li>Cortes premium y selección de carnes nacionales</li>
        <li>Acompañamientos y guarniciones de elaboración propia</li>
        <li>Servicio profesional con personal capacitado</li>
      </ul>
    </div>

    <div class="specialty__visual reveal" aria-hidden="true">
      <div
        class="specialty__video-frame"
        style={`--poster-bg: url(${specialtyPoster.src})`}
      >
        <video
          class="specialty__video"
          muted
          loop
          playsinline
          preload="none"
          poster={specialtyPoster.src}
          data-specialty-video
        >
          <source src={specialtyVideoMp4} type="video/mp4" />
        </video>
        <span class="specialty__badge">
          <span class="specialty__badge-num">25</span>
          <span class="specialty__badge-label">años</span>
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .specialty {
    padding: var(--space-section) 0;
    background: var(--color-ink);
    color: var(--color-bg);
    position: relative;
    overflow: hidden;
  }
  .specialty::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 60%;
    height: 80%;
    background: radial-gradient(circle, rgba(122, 31, 43, 0.4) 0%, transparent 60%);
    pointer-events: none;
  }
  .specialty__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    position: relative;
  }
  .specialty__text :global(.eyebrow) {
    color: var(--color-gold);
  }
  .specialty__lead {
    font-size: 1.0625rem;
    line-height: 1.65;
    margin: 1.75rem 0 2rem;
    color: rgba(244, 233, 216, 0.85);
    max-width: 540px;
  }
  .specialty__list {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .specialty__list li {
    position: relative;
    padding-left: 1.75rem;
    font-size: 0.9375rem;
    color: rgba(244, 233, 216, 0.85);
  }
  .specialty__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.625rem;
    width: 12px;
    height: 1px;
    background: var(--color-gold);
  }
  .specialty__visual {
    position: relative;
    width: min(100%, 440px);
    margin: 2.5rem auto 1rem;
    justify-self: center;
  }
  .specialty__video-frame {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: 6px;
    overflow: hidden;
    box-shadow:
      0 30px 60px -25px rgba(0, 0, 0, 0.65),
      0 0 0 1px rgba(201, 169, 97, 0.25);
  }
  .specialty__video-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(180deg, transparent 55%, rgba(15, 14, 12, 0.55) 100%);
  }
  .specialty__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    filter: contrast(1.08) saturate(1.15) brightness(0.94);
  }
  .specialty__badge {
    position: absolute;
    z-index: 3;
    bottom: -22px;
    right: -22px;
    width: 110px;
    height: 110px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, var(--color-wine) 0%, #4a121a 100%);
    border: 1px solid var(--color-gold);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: 0 20px 40px -15px rgba(122, 31, 43, 0.6);
  }
  .specialty__badge-num {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-style: italic;
    font-weight: 300;
    color: var(--color-gold);
    line-height: 1;
  }
  .specialty__badge-label {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(244, 233, 216, 0.85);
    margin-top: 0.35rem;
  }
  @media (min-width: 960px) {
    .specialty__inner {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 5rem;
      align-items: center;
    }
    .specialty__visual {
      margin: 0;
      width: 100%;
      max-width: 460px;
      justify-self: end;
    }
    .specialty__badge {
      width: 130px;
      height: 130px;
      bottom: -28px;
      right: -28px;
    }
    .specialty__badge-num {
      font-size: 3rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .specialty__video {
      display: none;
    }
    .specialty__video-frame {
      background-image: var(--poster-bg);
      background-size: cover;
      background-position: center;
    }
  }
</style>

<script>
  // El video se carga y reproduce sólo cuando la sección entra al viewport;
  // se pausa al salir para ahorrar CPU/datos.
  const specialty = document.querySelector<HTMLElement>('.specialty');
  const video = document.querySelector<HTMLVideoElement>('[data-specialty-video]');
  if (specialty && video && 'IntersectionObserver' in window) {
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          specialty.classList.toggle('is-in-view', entry.isIntersecting);
          if (entry.isIntersecting) {
            video.play().catch(() => {});
          } else {
            video.pause();
          }
        });
      },
      { threshold: 0.15 }
    );
    obs.observe(specialty);
  }
</script>
