---
/**
 * Sección "Nosotros" — foto del maestro parrillero + historia + highlights.
 */
import { Image } from 'astro:assets';
import chefPhoto from '~/assets/team/foto1.jpg';
import SectionHead from '~/components/ui/SectionHead.astro';
---

<section class="about" id="nosotros" aria-labelledby="about-title">
  <div class="container about__inner">
    <figure class="about__photo reveal">
      <Image
        src={chefPhoto}
        alt="Retrato del dueño y maestro parrillero de Fertomart"
        width={600}
        height={750}
        loading="lazy"
      />
      <figcaption class="about__caption">
        <span class="about__caption-name">Maestro parrillero · Fundador</span>
        <span class="about__caption-line"></span>
        <span class="about__caption-years">Oficio de legado · Toda una vida al fuego</span>
      </figcaption>
    </figure>

    <div class="about__text reveal">
      <SectionHead eyebrow="Nosotros" id="about-title">
        El oficio detrás de <em>cada evento</em>
      </SectionHead>
      <p class="about__lead">
        Fertomart nace el año 2000 como un proyecto familiar: ofrecer en cada celebración
        la misma calidad con que se cocina en casa, multiplicada por el oficio de un
        equipo que entiende el fuego.
      </p>
      <p class="about__body">
        Detrás del proyecto está nuestro dueño y maestro parrillero. Lo de él no son
        25 años: es un oficio de legado, transmitido de generación en generación y
        perfeccionado durante toda una vida frente a las brasas. Conoce los cortes,
        los tiempos y el punto exacto como solo se aprende cuando la parrilla es
        herencia familiar antes que profesión.
      </p>
      <p class="about__body">
        Esa tradición es la que separa un buen evento de uno inolvidable: atención al
        detalle, puntualidad y respetar lo que prometemos.
      </p>

      <div class="about__highlights">
        <div class="about__hl">
          <span class="about__hl-num">2000</span>
          <span class="about__hl-label">Año de fundación</span>
        </div>
        <div class="about__hl">
          <span class="about__hl-num">+1.000</span>
          <span class="about__hl-label">Eventos realizados</span>
        </div>
        <div class="about__hl">
          <span class="about__hl-num">100%</span>
          <span class="about__hl-label">Compromiso por evento</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding: var(--space-section) 0;
    background: var(--color-bg);
    position: relative;
    overflow: hidden;
  }
  .about::before {
    content: '';
    position: absolute;
    top: 10%;
    left: -10%;
    width: 50%;
    height: 60%;
    background: radial-gradient(ellipse, rgba(201, 169, 97, 0.18) 0%, transparent 65%);
    pointer-events: none;
  }
  .about__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    position: relative;
  }
  .about__photo {
    position: relative;
    max-width: 460px;
    margin: 0 auto;
    border-radius: 6px;
    overflow: hidden;
    isolation: isolate;
  }
  .about__photo::after {
    content: '';
    position: absolute;
    inset: -8px;
    border: 1px solid var(--color-gold);
    opacity: 0.4;
    pointer-events: none;
    z-index: -1;
    border-radius: 6px;
  }
  .about__photo :global(img) {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }
  .about__caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
    background: linear-gradient(to top, rgba(15, 14, 12, 0.88) 0%, rgba(15, 14, 12, 0.55) 60%, transparent 100%);
    color: var(--color-bg);
  }
  .about__caption-name {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-weight: 600;
  }
  .about__caption-line {
    display: block;
    width: 30px;
    height: 1px;
    background: var(--color-gold);
    opacity: 0.6;
  }
  .about__caption-years {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
  }
  .about__text {
    max-width: 560px;
  }
  .about__lead {
    font-size: 1.0625rem;
    line-height: 1.65;
    margin: 1.5rem 0 1rem;
    color: var(--color-ink-soft);
  }
  .about__body {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-ink-soft);
    margin-bottom: 2rem;
  }
  .about__highlights {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line);
  }
  .about__hl {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .about__hl-num {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 4vw, 1.85rem);
    color: var(--color-wine);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .about__hl-label {
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--color-ink-soft);
  }
  @media (min-width: 960px) {
    .about__inner {
      grid-template-columns: 0.9fr 1.1fr;
      gap: 5rem;
    }
    .about__photo {
      margin: 0;
      max-width: none;
    }
  }
</style>
