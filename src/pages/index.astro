---
/**
 * Página principal de Fertomart.
 * Esta es la "composición": cada sección es un componente importado.
 * Los Schema.org se generan dinámicamente desde las collections y se inyectan
 * en el <head> vía el layout.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Nav from '~/components/sections/Nav.astro';
import Hero from '~/components/sections/Hero.astro';
import Pillars from '~/components/sections/Pillars.astro';
import Services from '~/components/sections/Services.astro';
import About from '~/components/sections/About.astro';
import Specialty from '~/components/sections/Specialty.astro';
import Events from '~/components/sections/Events.astro';
import Gallery from '~/components/sections/Gallery.astro';
import Reels from '~/components/sections/Reels.astro';
import Process from '~/components/sections/Process.astro';
import Testimonials from '~/components/sections/Testimonials.astro';
import Faq from '~/components/sections/Faq.astro';
import Cta from '~/components/sections/Cta.astro';
import Lightbox from '~/components/sections/Lightbox.astro';
import WhatsAppFab from '~/components/sections/WhatsAppFab.astro';
import Footer from '~/components/sections/Footer.astro';
import { localBusinessSchema, faqSchemaFromCollection, videoSchemasFromReels } from '~/lib/seo';

import reel1 from '~/assets/reels/reel-evento-01.mp4';
import reel2 from '~/assets/reels/reel-evento-02.mp4';
import reel3 from '~/assets/reels/reel-evento-03.mp4';
import reel4 from '~/assets/reels/reel-evento-04.mp4';
import reel5 from '~/assets/reels/reel-cordero-palo.mp4';
import reel6 from '~/assets/reels/reel-banquete.mp4';

const faqs = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);

// Schemas estructurados para Google Rich Results: LocalBusiness + FAQ + Videos.
const reelMeta = [
  { src: reel1, title: 'Coctelería para eventos' },
  { src: reel2, title: 'Platos de entrada gourmet' },
  { src: reel3, title: 'Montaje de mesas para banquete' },
  { src: reel4, title: 'Eventos personalizados' },
  { src: reel5, title: 'Cocina sobre brasas y cordero al palo' },
  { src: reel6, title: 'Parrilladas para eventos' },
];

const schemas = [
  localBusinessSchema(),
  faqSchemaFromCollection(faqs),
  ...videoSchemasFromReels(reelMeta),
];
---

<BaseLayout schemas={schemas}>
  <Nav />
  <main id="inicio">
    <Hero />
    <Pillars />
    <Services />
    <About />
    <Specialty />
    <Events />
    <Gallery />
    <Reels />
    <Process />
    <Testimonials />
    <Faq />
    <Cta />
  </main>
  <Lightbox />
  <WhatsAppFab />
  <Footer />
</BaseLayout>

<script>
  // Activa las animaciones de scroll en toda la página
  import '~/scripts/scroll-reveal.ts';
</script>
